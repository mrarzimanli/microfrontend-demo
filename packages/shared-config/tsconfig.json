{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "allowJs": true,
        "checkJs": false,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js"]
}
